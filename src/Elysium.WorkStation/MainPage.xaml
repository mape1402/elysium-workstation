<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Elysium.WorkStation"
             x:Class="Elysium.WorkStation.MainPage"
             x:DataType="local:MainPage"
             Shell.NavBarIsVisible="False"
             Title="Workspace">

    <Grid Padding="18" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="Workspace"
                   StyleClass="PageTitle" />
            <Label Text="Selecciona un modulo desde el sidebar"
                   StyleClass="Muted" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                BackgroundColor="{Binding RoleStatusColor}"
                Padding="12,7"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 10">
            <Label Text="{Binding RoleStatusText}"
                   FontFamily="OpenSansRegular"
                   FontSize="12"
                   TextColor="White"
                   HorizontalOptions="Center" />
        </Border>

        <Border Grid.Row="2"
                Padding="16"
                Stroke="{AppThemeBinding Light=#C9DBF8, Dark=#425A82}"
                BackgroundColor="{AppThemeBinding Light=#F8FBFF, Dark=#1F2B3F}"
                StrokeShape="RoundRectangle 14">
            <VerticalStackLayout Spacing="10">
                <Label Text="Panel principal"
                       StyleClass="SectionTitle" />
                <Label Text="Ahora la app usa un sidebar real para navegar entre modulos dentro del contenedor principal."
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light=#5F6F8D, Dark=#AABBDD}" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,4,0,0">
                    <Button Grid.Column="0"
                            Text="Variables"
                            Command="{Binding OpenVariablesCommand}" />
                    <Button Grid.Column="1"
                            Text="Kanban"
                            Command="{Binding OpenKanbanCommand}" />
                    <Button Grid.Column="2"
                            Text="Notas"
                            Command="{Binding OpenNotesCommand}" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>

