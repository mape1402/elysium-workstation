<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Elysium.WorkStation.Models"
             xmlns:views="clr-namespace:Elysium.WorkStation.Views"
             x:Class="Elysium.WorkStation.Views.NotesPage"
             x:DataType="views:NotesPage"
             Title="Notas rápidas">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8"
              Padding="16,10,16,6">
            <Label Grid.Column="0"
                   Text="{Binding CountText}"
                   FontFamily="OpenSansSemibold"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="📝 Nueva"
                    Command="{Binding AddCommand}"
                    FontFamily="OpenSansSemibold"
                    FontSize="12"
                    CornerRadius="8"
                    HeightRequest="32"
                    Padding="12,0" />
            <Button Grid.Column="2"
                    Text="Limpiar todo"
                    Command="{Binding ClearCommand}"
                    FontFamily="OpenSansSemibold"
                    FontSize="12"
                    CornerRadius="8"
                    HeightRequest="32"
                    Padding="12,0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray200}}" />
        </Grid>

        <!-- Post-it grid -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Notes}"
                        Margin="12,4,12,12">

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10"
                                     Margin="0,80,0,0">
                    <Label Text="📝"
                           FontSize="52"
                           HorizontalOptions="Center" />
                    <Label Text="No hay notas todavía"
                           FontFamily="OpenSansRegular"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="4"
                                 HorizontalItemSpacing="10"
                                 VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NoteEntry">
                    <Border Padding="0"
                            HeightRequest="170"
                            StrokeShape="RoundRectangle 4"
                            StrokeThickness="0"
                            BackgroundColor="{Binding NoteColor}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="2,3" Radius="8" Opacity="0.18" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:NotesPage}}, Path=EditCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid RowDefinitions="Auto,1,*,Auto" RowSpacing="0" Padding="14,10,14,8">

                            <!-- Title row + action buttons -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                                <Label Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="#3E2723"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"
                                       VerticalOptions="Center" />
                                <Border Grid.Column="1"
                                        WidthRequest="28"
                                        HeightRequest="28"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="0"
                                        BackgroundColor="#30000000"
                                        Padding="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type views:NotesPage}}, Path=CopyCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="📋"
                                           FontSize="14"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                <Border Grid.Column="2"
                                        WidthRequest="28"
                                        HeightRequest="28"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="0"
                                        BackgroundColor="#44000000"
                                        Padding="0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type views:NotesPage}}, Path=DeleteCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="✕"
                                           FontSize="14"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <!-- Separator -->
                            <BoxView Grid.Row="1"
                                     Color="#D7CCC8"
                                     HeightRequest="1"
                                     Margin="0,6,0,6"
                                     HorizontalOptions="Fill" />

                            <!-- Body text -->
                            <Label Grid.Row="2"
                                   Text="{Binding Text}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="12"
                                   TextColor="#4E342E"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="4" />

                            <!-- Footer: timestamp -->
                            <Label Grid.Row="3"
                                   Text="{Binding TimeDisplay}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="10"
                                   TextColor="#8D6E63"
                                   Margin="0,4,0,0"
                                   HorizontalOptions="End" />

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
