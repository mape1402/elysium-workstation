<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Elysium.WorkStation.Views"
             x:Class="Elysium.WorkStation.Views.GroupEditorPage"
             x:DataType="views:GroupEditorPage"
             Title="{Binding PageTitle}">

    <Grid RowDefinitions="*,Auto"
          Padding="18"
          RowSpacing="14">

        <VerticalStackLayout Spacing="10">
            <Label Text="{Binding HeaderText}"
                   FontFamily="OpenSansSemibold"
                   FontSize="18" />

            <Label Text="Nombre del grupo"
                   FontFamily="OpenSansSemibold"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#5E5E5E, Dark=#B8B8B8}" />

            <Entry x:Name="NameEntry"
                   Placeholder="Ej. Configuración email"
                   ClearButtonVisibility="WhileEditing" />

            <Label Text="Descripción (opcional)"
                   FontFamily="OpenSansSemibold"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light=#5E5E5E, Dark=#B8B8B8}" />

            <Editor x:Name="DescriptionEditor"
                    HeightRequest="140"
                    Placeholder="Describe para qué usarás este grupo..." />
        </VerticalStackLayout>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="Cancelar"
                    Clicked="OnCancelClicked"
                    BackgroundColor="{AppThemeBinding Light=#ECECEC, Dark=#3B3B3B}"
                    TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F5F5F5}" />
            <Button Grid.Column="1"
                    Text="{Binding SaveButtonText}"
                    Clicked="OnSaveClicked" />
        </Grid>
    </Grid>
</ContentPage>
