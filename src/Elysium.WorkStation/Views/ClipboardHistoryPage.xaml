<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Elysium.WorkStation.Models"
             x:Class="Elysium.WorkStation.Views.ClipboardHistoryPage"
             Title="Portapapeles">

    <Grid RowDefinitions="Auto,Auto,*">

        <Border Grid.Row="0"
                BackgroundColor="{Binding StatusColor}"
                Padding="12,6">
            <Label Text="{Binding StatusText}"
                   FontFamily="OpenSansRegular"
                   FontSize="12"
                   TextColor="White"
                   HorizontalOptions="Center" />
        </Border>

        <Button Grid.Row="1"
                Text="Enviar portapapeles"
                Command="{Binding SendCommand}"
                FontFamily="OpenSansSemibold"
                FontSize="14"
                Margin="16,10"
                HorizontalOptions="Fill"
                CornerRadius="12" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding History}"
                        Margin="16,12">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Margin="32">
                    <Label Text="📋"
                           FontSize="48"
                           HorizontalOptions="Center" />
                    <Label Text="No hay entradas aún"
                           FontFamily="OpenSansSemibold"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                    <Label Text="Presiona el boton para enviar el texto del portapapeles"
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ClipboardEntry">
                    <Border Padding="16,12"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,1" Radius="6" Opacity="0.06" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Text}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="13"
                                   MaxLines="3"
                                   LineBreakMode="TailTruncation"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding SenderDisplay}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="11"
                                   Margin="0,4,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Text="📋"
                                    FontSize="18"
                                    BackgroundColor="Transparent"
                                    Padding="8"
                                    VerticalOptions="Center"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=CopyCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
