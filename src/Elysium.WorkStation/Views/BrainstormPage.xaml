<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Elysium.WorkStation.Models"
             xmlns:views="clr-namespace:Elysium.WorkStation.Views"
             x:Class="Elysium.WorkStation.Views.BrainstormPage"
             x:DataType="views:BrainstormPage"
             Title="Brainstorming">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0"
              Padding="16,12,16,8"
              ColumnDefinitions="*"
              ColumnSpacing="10">
            <VerticalStackLayout Spacing="6">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Button Grid.Column="0"
                            Text="Volver"
                            Command="{Binding BackCommand}"
                            FontSize="12"
                            FontFamily="OpenSansSemibold"
                            HeightRequest="30"
                            VerticalOptions="Center"
                            CornerRadius="8"
                            Padding="10,0"
                            BackgroundColor="{AppThemeBinding Light=#E8F0FF, Dark=#31425E}"
                            TextColor="{AppThemeBinding Light=#274C9B, Dark=#D8E6FF}">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnNavHoverEntered"
                                                      PointerExited="OnNavHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                    <Grid Grid.Column="1"
                          VerticalOptions="Center">
                        <ScrollView x:Name="BreadcrumbScrollView"
                                    Orientation="Horizontal"
                                    HeightRequest="72"
                                    VerticalOptions="Center"
                                    HorizontalOptions="FillAndExpand"
                                    HorizontalScrollBarVisibility="Always"
                                    VerticalScrollBarVisibility="Never"
                                    Loaded="OnBreadcrumbLoaded"
                                    SizeChanged="OnBreadcrumbSizeChanged">
                            <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Breadcrumbs}"
                                                   Spacing="2"
                                                   Padding="0,2,10,14">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="views:BrainstormBreadcrumbItem">
                                        <Grid ColumnDefinitions="Auto,Auto"
                                              ColumnSpacing="2">
                                            <Border Grid.Column="0"
                                                    x:Name="BreadcrumbChip"
                                                    StrokeThickness="1"
                                                    Stroke="{AppThemeBinding Light=#F1D09C, Dark=#725537}"
                                                    BackgroundColor="{AppThemeBinding Light=#FFF1DC, Dark=#4C3928}"
                                                    Padding="10,4"
                                                    VerticalOptions="Center"
                                                    MinimumHeightRequest="28"
                                                    StrokeShape="RoundRectangle 6">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type views:BrainstormPage}}, Path=NavigatePathCommand}"
                                                                          CommandParameter="{Binding .}" />
                                                    <PointerGestureRecognizer PointerEntered="OnBreadcrumbHoverEntered"
                                                                              PointerExited="OnBreadcrumbHoverExited" />
                                                </Border.GestureRecognizers>
                                                <Label x:Name="BreadcrumbText"
                                                       Text="{Binding Title}"
                                                       FontSize="11"
                                                       FontFamily="OpenSansSemibold"
                                                       VerticalOptions="Center"
                                                       TextColor="{AppThemeBinding Light=#8A4B00, Dark=#FFD7A4}">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsCurrent}"
                                                                     Value="True">
                                                            <Setter Property="TextColor"
                                                                    Value="{AppThemeBinding Light=#1F6A36, Dark=#D9F7E2}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding IsCurrent}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor"
                                                                Value="{AppThemeBinding Light=#E9F8EC, Dark=#2E5138}" />
                                                        <Setter Property="Stroke"
                                                                Value="{AppThemeBinding Light=#A9DAB6, Dark=#4D7A58}" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                            </Border>

                                            <Label Grid.Column="1"
                                                   Text=">"
                                                   IsVisible="{Binding ShowSeparator}"
                                                   VerticalOptions="Center"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   Margin="1,0,3,0"
                                                   TextColor="{AppThemeBinding Light=#9A6C2F, Dark=#E8CDAA}" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>
                        </ScrollView>
                    </Grid>

                    <Button Grid.Column="2"
                            Text="Menu"
                            Command="{Binding GoMenuCommand}"
                            FontSize="12"
                            FontFamily="OpenSansSemibold"
                            HeightRequest="30"
                            VerticalOptions="Center"
                            CornerRadius="8"
                            Padding="10,0"
                            BackgroundColor="{AppThemeBinding Light=#E8F0FF, Dark=#31425E}"
                            TextColor="{AppThemeBinding Light=#274C9B, Dark=#D8E6FF}">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnNavHoverEntered"
                                                      PointerExited="OnNavHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>
                </Grid>

                <Label Text="{Binding ContextText}"
                       FontFamily="OpenSansSemibold"
                       FontSize="14" />
                <Label Text="{Binding CountText}"
                       FontFamily="OpenSansRegular"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1">
            <CollectionView ItemsSource="{Binding Nodes}"
                            Margin="12,6,12,76">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="8"
                                         Margin="0,50,0,0">
                        <Label Text="Sin resultados"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding EmptyText}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                               HorizontalTextAlignment="Center"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="4"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BrainstormNode">
                        <Grid RowDefinitions="Auto">
                            <Border x:Name="BrainstormCard"
                                    Grid.Row="0"
                                    Padding="10"
                                    HeightRequest="66"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light=#D7E0F5, Dark=#3E4A63}"
                                    BackgroundColor="{AppThemeBinding Light=#F8FAFF, Dark=#1F2A3B}">
                                <Border.Shadow>
                                    <Shadow Brush="#330E1A33"
                                            Offset="0,4"
                                            Radius="10"
                                            Opacity="0.9" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:BrainstormPage}}, Path=OpenChildrenCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Label Text="{Binding Title}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </Border>

                            <Grid Grid.Row="0"
                                  x:Name="BrainstormActions"
                                  ColumnDefinitions="*,*,*"
                                  ColumnSpacing="6"
                                  IsVisible="False"
                                  Opacity="0"
                                  HorizontalOptions="Center"
                                  VerticalOptions="End"
                                  Margin="0,0,0,-20">
                                <Button Grid.Column="0"
                                        Text="&#x1F441;"
                                        WidthRequest="35"
                                        HeightRequest="35"
                                        MinimumWidthRequest="35"
                                        MinimumHeightRequest="35"
                                        FontSize="13"
                                        Padding="0"
                                        CornerRadius="7"
                                        ToolTipProperties.Text="Ver detalle"
                                        BackgroundColor="{AppThemeBinding Light=#E8F0FF, Dark=#31425E}"
                                        TextColor="{AppThemeBinding Light=#274C9B, Dark=#D8E6FF}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:BrainstormPage}}, Path=ViewCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="1"
                                        Text="&#x270E;"
                                        WidthRequest="35"
                                        HeightRequest="35"
                                        MinimumWidthRequest="35"
                                        MinimumHeightRequest="35"
                                        FontSize="13"
                                        Padding="0"
                                        CornerRadius="7"
                                        FontFamily="OpenSansSemibold"
                                        ToolTipProperties.Text="Editar"
                                        BackgroundColor="{AppThemeBinding Light=#E8F0FF, Dark=#31425E}"
                                        TextColor="{AppThemeBinding Light=#274C9B, Dark=#D8E6FF}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:BrainstormPage}}, Path=EditCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="2"
                                        Text="&#x1F5D1;"
                                        WidthRequest="35"
                                        HeightRequest="35"
                                        MinimumWidthRequest="35"
                                        MinimumHeightRequest="35"
                                        FontSize="13"
                                        Padding="0"
                                        CornerRadius="7"
                                        ToolTipProperties.Text="Eliminar"
                                        BackgroundColor="{AppThemeBinding Light=#FDECEF, Dark=#5B2228}"
                                        TextColor="{AppThemeBinding Light=#9C1F2F, Dark=#FFDCE1}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:BrainstormPage}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup Name="CommonStates">
                                    <VisualState Name="Normal">
                                        <VisualState.Setters>
                                            <Setter TargetName="BrainstormActions" Property="IsVisible" Value="False" />
                                            <Setter TargetName="BrainstormActions" Property="Opacity" Value="0" />
                                            <Setter TargetName="BrainstormCard" Property="Scale" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter TargetName="BrainstormActions" Property="IsVisible" Value="True" />
                                            <Setter TargetName="BrainstormActions" Property="Opacity" Value="1" />
                                            <Setter TargetName="BrainstormCard" Property="Scale" Value="1.02" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,18,18"
                    BackgroundColor="{AppThemeBinding Light=#1E56D9, Dark=#2D6BFF}"
                    StrokeThickness="0"
                    WidthRequest="54"
                    HeightRequest="54"
                    StrokeShape="RoundRectangle 27"
                    Shadow="{x:Null}">
                <Border.Shadow>
                    <Shadow Brush="#55223D7A"
                            Offset="0,5"
                            Radius="14"
                            Opacity="1" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddCommand}" />
                </Border.GestureRecognizers>
                <Label Text="+"
                       FontSize="26"
                       FontFamily="OpenSansSemibold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>

