<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Elysium.WorkStation.Models"
             xmlns:views="clr-namespace:Elysium.WorkStation.Views"
             x:Class="Elysium.WorkStation.Views.KanbanPage"
             x:DataType="views:KanbanPage"
             Title="Kanban">

    <ScrollView Orientation="Horizontal">
        <Grid ColumnDefinitions="*,*,*,*"
              ColumnSpacing="8"
              Padding="12,8,12,12"
              MinimumWidthRequest="900">

                <!-- ═══ Pendiente ═══ -->
                <Border x:Name="ColumnPending"
                        Grid.Column="0"
                        Padding="10,8"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D5D5D5, Dark=#555555}"
                        StrokeThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{AppThemeBinding Light=#F5F5F5, Dark=#2E2E2E}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#EEEEEE, Dark=#252525}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#E0E0E0, Dark=#1E1E1E}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnDragOver"
                                               DragLeave="OnDragLeave"
                                               Drop="OnDropPending" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="⏳ Pendiente"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                   VerticalOptions="Center" />
                            <Border Grid.Row="0" Grid.Column="1"
                                    HeightRequest="22" WidthRequest="22"
                                    StrokeShape="Ellipse"
                                    Stroke="{AppThemeBinding Light=#BDBDBD, Dark=#616161}"
                                    StrokeThickness="1"
                                    BackgroundColor="Transparent"
                                    ToolTipProperties.Text="Agregar tarea">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddCommand}" CommandParameter="Pending" />
                                </Border.GestureRecognizers>
                                <Label Text="➕"
                                       FontSize="10"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                     HeightRequest="2" Color="{AppThemeBinding Light=#BDBDBD, Dark=#616161}" Margin="0,0,0,4" />
                        </Grid>
                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding PendingTasks}"
                                        x:DataType="views:KanbanPage">
                            <CollectionView.EmptyView>
                                <Label Text="Arrastra tareas aquí"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       HorizontalOptions="Center"
                                       Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:KanbanTask">
                                    <Border Padding="10,8"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#484848}"
                                            StrokeThickness="0.5"
                                            BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#333333}">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="1,2" Radius="6" Opacity="0.12" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <DragGestureRecognizer CanDrag="True"
                                                                   DragStarting="OnDragStarting" />
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=EditCommand}"
                                                CommandParameter="{Binding .}" />
                                            <PointerGestureRecognizer PointerEntered="OnCardPointerEntered"
                                                                     PointerExited="OnCardPointerExited" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="13"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#424242, Dark=#E0E0E0}" />
                                                <Label Text="{Binding Description}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="11"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#757575, Dark=#BDBDBD}"
                                                       IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                                                <Label Text="{Binding TimeDisplay}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="10"
                                                       TextColor="{AppThemeBinding Light=#9E9E9E, Dark=#757575}" />
                                            </VerticalStackLayout>
                                            <Border HeightRequest="20" WidthRequest="20"
                                                    StrokeShape="Ellipse"
                                                    Stroke="{AppThemeBinding Light=#BDBDBD, Dark=#757575}"
                                                    StrokeThickness="1"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="End" VerticalOptions="Start"
                                                    Margin="0,-4,-4,0"
                                                    Opacity="0"
                                                    ToolTipProperties.Text="Eliminar">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=DeleteCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="🗑"
                                                       FontSize="10"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <!-- ═══ En Progreso ═══ -->
                <Border x:Name="ColumnInProgress"
                        Grid.Column="1"
                        Padding="10,8"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#B3D4FC, Dark=#1565C0}"
                        StrokeThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{AppThemeBinding Light=#E3F2FD, Dark=#0D2137}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#BBDEFB, Dark=#0A1929}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#90CAF9, Dark=#071320}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnDragOver"
                                               DragLeave="OnDragLeave"
                                               Drop="OnDropInProgress" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="🔄 En Progreso"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#1565C0, Dark=#64B5F6}"
                                   VerticalOptions="Center" />
                            <Border Grid.Row="0" Grid.Column="1"
                                    HeightRequest="22" WidthRequest="22"
                                    StrokeShape="Ellipse"
                                    Stroke="{AppThemeBinding Light=#42A5F5, Dark=#1E88E5}"
                                    StrokeThickness="1"
                                    BackgroundColor="Transparent"
                                    ToolTipProperties.Text="Agregar tarea">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddCommand}" CommandParameter="InProgress" />
                                </Border.GestureRecognizers>
                                <Label Text="➕"
                                       FontSize="10"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                     HeightRequest="2" Color="{AppThemeBinding Light=#42A5F5, Dark=#1E88E5}" Margin="0,0,0,4" />
                        </Grid>
                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding InProgressTasks}"
                                        x:DataType="views:KanbanPage">
                            <CollectionView.EmptyView>
                                <Label Text="Arrastra tareas aquí"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       HorizontalOptions="Center"
                                       Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:KanbanTask">
                                    <Border Padding="10,8"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="{AppThemeBinding Light=#D6EAF8, Dark=#1A3A5C}"
                                            StrokeThickness="0.5"
                                            BackgroundColor="{AppThemeBinding Light=#E8F4FD, Dark=#1C2E3E}">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="1,2" Radius="6" Opacity="0.12" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <DragGestureRecognizer CanDrag="True"
                                                                   DragStarting="OnDragStarting" />
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=EditCommand}"
                                                CommandParameter="{Binding .}" />
                                            <PointerGestureRecognizer PointerEntered="OnCardPointerEntered"
                                                                     PointerExited="OnCardPointerExited" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="13"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#1A237E, Dark=#B3D4FC}" />
                                                <Label Text="{Binding Description}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="11"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#5472A0, Dark=#7DA5CC}"
                                                       IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                                                <Label Text="{Binding TimeDisplay}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="10"
                                                       TextColor="{AppThemeBinding Light=#90A4AE, Dark=#607D8B}" />
                                            </VerticalStackLayout>
                                            <Border HeightRequest="20" WidthRequest="20"
                                                    StrokeShape="Ellipse"
                                                    Stroke="{AppThemeBinding Light=#90CAF9, Dark=#1565C0}"
                                                    StrokeThickness="1"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="End" VerticalOptions="Start"
                                                    Margin="0,-4,-4,0"
                                                    Opacity="0"
                                                    ToolTipProperties.Text="Eliminar">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=DeleteCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="🗑"
                                                       FontSize="10"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <!-- ═══ Bloqueado ═══ -->
                <Border x:Name="ColumnBlocked"
                        Grid.Column="2"
                        Padding="10,8"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#FFCC80, Dark=#E65100}"
                        StrokeThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{AppThemeBinding Light=#FFF3E0, Dark=#3E2200}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#FFE0B2, Dark=#2E1A00}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#FFCC80, Dark=#1F1200}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnDragOver"
                                               DragLeave="OnDragLeave"
                                               Drop="OnDropBlocked" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="⚠️ Bloqueado"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}"
                                   VerticalOptions="Center" />
                            <Border Grid.Row="0" Grid.Column="1"
                                    HeightRequest="22" WidthRequest="22"
                                    StrokeShape="Ellipse"
                                    Stroke="{AppThemeBinding Light=#FB8C00, Dark=#F57C00}"
                                    StrokeThickness="1"
                                    BackgroundColor="Transparent"
                                    ToolTipProperties.Text="Agregar tarea">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddCommand}" CommandParameter="Blocked" />
                                </Border.GestureRecognizers>
                                <Label Text="➕"
                                       FontSize="10"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                     HeightRequest="2" Color="{AppThemeBinding Light=#FB8C00, Dark=#F57C00}" Margin="0,0,0,4" />
                        </Grid>
                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding BlockedTasks}"
                                        x:DataType="views:KanbanPage">
                            <CollectionView.EmptyView>
                                <Label Text="Arrastra tareas aquí"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       HorizontalOptions="Center"
                                       Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:KanbanTask">
                                    <Border Padding="10,8"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="{AppThemeBinding Light=#FFE0B2, Dark=#5D3A00}"
                                            StrokeThickness="0.5"
                                            BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#3E2D10}">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="1,2" Radius="6" Opacity="0.12" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <DragGestureRecognizer CanDrag="True"
                                                                   DragStarting="OnDragStarting" />
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=EditCommand}"
                                                CommandParameter="{Binding .}" />
                                            <PointerGestureRecognizer PointerEntered="OnCardPointerEntered"
                                                                     PointerExited="OnCardPointerExited" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="13"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#BF360C, Dark=#FFCC80}" />
                                                <Label Text="{Binding Description}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="11"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#A1887F, Dark=#BCAAA4}"
                                                       IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                                                <Label Text="{Binding TimeDisplay}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="10"
                                                       TextColor="{AppThemeBinding Light=#BCAAA4, Dark=#8D6E63}" />
                                            </VerticalStackLayout>
                                            <Border HeightRequest="20" WidthRequest="20"
                                                    StrokeShape="Ellipse"
                                                    Stroke="{AppThemeBinding Light=#FFCC80, Dark=#E65100}"
                                                    StrokeThickness="1"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="End" VerticalOptions="Start"
                                                    Margin="0,-4,-4,0"
                                                    Opacity="0"
                                                    ToolTipProperties.Text="Eliminar">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=DeleteCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="🗑"
                                                       FontSize="10"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <!-- ═══ Terminado ═══ -->
                <Border x:Name="ColumnDone"
                        Grid.Column="3"
                        Padding="10,8"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#A5D6A7, Dark=#2E7D32}"
                        StrokeThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="{AppThemeBinding Light=#E8F5E9, Dark=#0A2E0A}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#C8E6C9, Dark=#072107}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#A5D6A7, Dark=#051A05}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <DropGestureRecognizer AllowDrop="True"
                                               DragOver="OnDragOver"
                                               DragLeave="OnDragLeave"
                                               Drop="OnDropDone" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*" RowSpacing="8">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="✅ Terminado"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}"
                                   VerticalOptions="Center" />
                            <Border Grid.Row="0" Grid.Column="1"
                                    HeightRequest="22" WidthRequest="22"
                                    StrokeShape="Ellipse"
                                    Stroke="{AppThemeBinding Light=#66BB6A, Dark=#43A047}"
                                    StrokeThickness="1"
                                    BackgroundColor="Transparent"
                                    ToolTipProperties.Text="Agregar tarea">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddCommand}" CommandParameter="Done" />
                                </Border.GestureRecognizers>
                                <Label Text="➕"
                                       FontSize="10"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                     HeightRequest="2" Color="{AppThemeBinding Light=#66BB6A, Dark=#43A047}" Margin="0,0,0,4" />
                        </Grid>
                        <CollectionView Grid.Row="1"
                                        ItemsSource="{Binding DoneTasks}"
                                        x:DataType="views:KanbanPage">
                            <CollectionView.EmptyView>
                                <Label Text="Arrastra tareas aquí"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                                       HorizontalOptions="Center"
                                       Margin="0,20,0,0" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:KanbanTask">
                                    <Border Padding="10,8"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#1B4A1B}"
                                            StrokeThickness="0.5"
                                            BackgroundColor="{AppThemeBinding Light=#F1F8E9, Dark=#1A2E1A}">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="1,2" Radius="6" Opacity="0.12" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <DragGestureRecognizer CanDrag="True"
                                                                   DragStarting="OnDragStarting" />
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=EditCommand}"
                                                CommandParameter="{Binding .}" />
                                            <PointerGestureRecognizer PointerEntered="OnCardPointerEntered"
                                                                     PointerExited="OnCardPointerExited" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Title}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="13"
                                                       LineBreakMode="TailTruncation"
                                                       TextDecorations="Strikethrough"
                                                       TextColor="{AppThemeBinding Light=#66BB6A, Dark=#558B2F}" />
                                                <Label Text="{Binding Description}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="11"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{AppThemeBinding Light=#A5D6A7, Dark=#4E6E4E}"
                                                       IsVisible="{Binding Description, Converter={StaticResource IsNotNullOrEmptyConverter}}" />
                                                <Label Text="{Binding TimeDisplay}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="10"
                                                       TextColor="{AppThemeBinding Light=#A5D6A7, Dark=#4E6E4E}" />
                                            </VerticalStackLayout>
                                            <Border HeightRequest="20" WidthRequest="20"
                                                    StrokeShape="Ellipse"
                                                    Stroke="{AppThemeBinding Light=#A5D6A7, Dark=#2E7D32}"
                                                    StrokeThickness="1"
                                                    BackgroundColor="Transparent"
                                                    HorizontalOptions="End" VerticalOptions="Start"
                                                    Margin="0,-4,-4,0"
                                                    Opacity="0"
                                                    ToolTipProperties.Text="Eliminar">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type views:KanbanPage}}, Path=DeleteCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="🗑"
                                                       FontSize="10"
                                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                    </Grid>
                </ScrollView>

            </ContentPage>
