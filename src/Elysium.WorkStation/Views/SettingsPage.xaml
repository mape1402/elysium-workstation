<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Elysium.WorkStation.Views"
             x:Class="Elysium.WorkStation.Views.SettingsPage"
             x:DataType="views:SettingsPage"
             Title="Configuración">

    <Grid RowDefinitions="*,Auto,Auto" RowSpacing="0">

    <ScrollView Grid.Row="0">
        <VerticalStackLayout Padding="24,20" Spacing="24">

            <Border Padding="20,16"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.07" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">

                    <Label Text="🌐  URL del servidor"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />

                    <Label Text="URL base del servidor remoto al que se conectarán los clientes (incluye host y puerto)."
                           FontFamily="OpenSansRegular"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                    <Entry Text="{Binding ServerUrl}"
                           Placeholder="http://192.168.1.100:5050"
                           FontFamily="OpenSansRegular"
                           FontSize="14"
                           Keyboard="Url"
                           ClearButtonVisibility="WhileEditing" />

                </VerticalStackLayout>
            </Border>

            <Border Padding="20,16"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.07" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="16">

                    <Label Text="🗑️  Retención de datos"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />

                    <Label Text="Tiempo en horas tras el cual se eliminan automáticamente los datos de cada categoría."
                           FontFamily="OpenSansRegular"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                    <!-- Files -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📂  Archivos compartidos"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Entry Text="{Binding FileRetentionHours}"
                               Placeholder="72"
                               FontFamily="OpenSansRegular"
                               FontSize="14"
                               Keyboard="Numeric"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <!-- Clipboard -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📋  Historial del portapapeles"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Entry Text="{Binding ClipboardRetentionHours}"
                               Placeholder="72"
                               FontFamily="OpenSansRegular"
                               FontSize="14"
                               Keyboard="Numeric"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <!-- Notifications -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="🔔  Notificaciones"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Entry Text="{Binding NotificationRetentionHours}"
                               Placeholder="72"
                               FontFamily="OpenSansRegular"
                               FontSize="14"
                               Keyboard="Numeric"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <!-- Kanban cleanup -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📋  Kanban – Retención (días)"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Entry Text="{Binding KanbanCleanupRetentionDays}"
                               Placeholder="7"
                               FontFamily="OpenSansRegular"
                               FontSize="14"
                               Keyboard="Numeric"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="⏱️  Kanban – Intervalo de limpieza (horas)"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Entry Text="{Binding KanbanCleanupIntervalHours}"
                               Placeholder="1"
                               FontFamily="OpenSansRegular"
                               FontSize="14"
                               Keyboard="Numeric"
                               ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Startup with Windows -->
            <Border Padding="20,16"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.07" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">

                    <Label Text="🚀  Inicio con Windows"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />

                    <Label Text="Permite que la aplicación se inicie automáticamente al encender el equipo."
                           FontFamily="OpenSansRegular"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Iniciar con Windows"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding StartWithWindows}"
                                VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Mouse schedule -->
            <Border Padding="20,16"
                    StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.07" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">

                    <Label Text="🖱️  Movimiento del mouse"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />

                    <Label Text="Simula actividad moviendo el mouse automáticamente dentro del horario configurado."
                           FontFamily="OpenSansRegular"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />

                    <!-- Enabled toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Activar movimiento automático"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding MouseEnabled}"
                                VerticalOptions="Center" />
                    </Grid>

                    <!-- Schedule mode toggle -->
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding MouseEnabled}">
                        <Label Grid.Column="0"
                               Text="Usar horario general (todos los días)"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding MouseUseGeneralSchedule}"
                                VerticalOptions="Center" />
                    </Grid>

                    <!-- General schedule -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12"
                          IsVisible="{Binding ShowGeneralSchedule}">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Hora inicio"
                                   FontFamily="OpenSansRegular"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <TimePicker Time="{Binding MouseGeneralStartTime}"
                                        FontFamily="OpenSansRegular"
                                        FontSize="14"
                                        Format="HH:mm" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Hora fin"
                                   FontFamily="OpenSansRegular"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                            <TimePicker Time="{Binding MouseGeneralEndTime}"
                                        FontFamily="OpenSansRegular"
                                        FontSize="14"
                                        Format="HH:mm" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Per-day schedule -->
                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding ShowDaySchedule}">
                        <Label Text="Horario por día"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />

                        <CollectionView ItemsSource="{Binding MouseDaySchedules}"
                                        x:DataType="views:SettingsPage">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="views:DayScheduleViewModel">
                                    <Border Padding="12,8"
                                            StrokeShape="RoundRectangle 10"
                                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                            StrokeThickness="1"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                              ColumnSpacing="10"
                                              RowDefinitions="Auto"
                                              VerticalOptions="Center">
                                            <Switch Grid.Column="0"
                                                    IsToggled="{Binding IsEnabled}"
                                                    VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding DayName}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="13"
                                                   VerticalOptions="Center"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray800}, Dark={StaticResource Gray200}}" />
                                            <TimePicker Grid.Column="2"
                                                        Time="{Binding StartTime}"
                                                        FontFamily="OpenSansRegular"
                                                        FontSize="13"
                                                        Format="HH:mm"
                                                        IsEnabled="{Binding IsEnabled}" />
                                            <TimePicker Grid.Column="3"
                                                        Time="{Binding EndTime}"
                                                        FontFamily="OpenSansRegular"
                                                        FontSize="13"
                                                        Format="HH:mm"
                                                        IsEnabled="{Binding IsEnabled}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

    <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12" Padding="24,12,24,0">
                <Button Grid.Column="0"
                        Text="💾  Guardar"
                        Command="{Binding SaveCommand}"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        CornerRadius="12" />
                <Button Grid.Column="1"
                        Text="🔌  Probar conexión"
                        Command="{Binding TestCommand}"
                        FontFamily="OpenSansSemibold"
                        FontSize="14"
                        CornerRadius="12"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
            </Grid>

            <Border Grid.Row="2"
                    IsVisible="{Binding HasFeedback}"
                    BackgroundColor="{Binding FeedbackColor}"
                    Padding="14,10"
                    Margin="24,8,24,16"
                    StrokeShape="RoundRectangle 10"
                    StrokeThickness="0">
                <Label Text="{Binding FeedbackText}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       TextColor="White"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </Border>

    </Grid>

</ContentPage>
